{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/apify/run",
      "dest": "/api/apify/run.mjs"
    },
    {
      "src": "/api/agent/session",
      "dest": "/api/agent/session.mjs"
    },
    {
      "src": "/api/agent/actions",
      "dest": "/api/agent/actions.mjs"
    },
    {
      "src": "/api/agent/execute",
      "dest": "/api/agent/execute.mjs"
    },
    {
      "src": "/api/agent/autonomy",
      "dest": "/api/agent/autonomy.mjs"
    },
    {
      "src": "/api/agent/autonomy/run",
      "dest": "/api/agent/autonomy.mjs"
    },
    {
      "src": "/api/agent/inbox",
      "dest": "/api/agent/inbox.mjs"
    },
    {
      "src": "/api/agent/message",
      "dest": "/api/agent/message.mjs"
    },
    {
      "src": "/api/agent/approve",
      "dest": "/api/agent/approve.mjs"
    },
    {
      "src": "/api/agent/audit",
      "dest": "/api/agent/audit.mjs"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.mjs"
    },
    {
      "src": "/api/sources",
      "dest": "/api/sources.mjs"
    },
    {
      "src": "/api/intel",
      "dest": "/api/intel.mjs"
    },
    {
      "src": "/api/restock",
      "dest": "/api/restock.mjs"
    },
    {
      "src": "/app.js",
      "dest": "/public/app.js"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
