# Copy to .env and fill in values you want.
# All keys are optional — Warden runs without them on free public APIs.

# Apify Actor token (get from https://console.apify.com/account/integrations).
# When set, /api/intel uses Google Places via Apify for the market scan
# instead of OpenStreetMap Overpass. Set APIFY_PLACES_DISABLED=1 to keep
# the token but skip the per-scan cost.
APIFY_TOKEN=replace_with_event_token

# Optional: override the Maps actor. Default is compass/crawler-google-places.
# Other options: lukaskrivka/google-maps-with-contact-details, apify/google-maps-scraper.
APIFY_PLACES_ACTOR=compass/crawler-google-places

# Optional: cap places per search (default 25). Lower = cheaper.
APIFY_MAX_PLACES=25

# Set to 1 to disable Apify market scan even when APIFY_TOKEN is present.
APIFY_PLACES_DISABLED=

# Apify product-scraper actor for live restock images. Default is an Amazon search
# scraper. Override to walmart/google-shopping/etc. depending on what you have access to.
APIFY_PRODUCTS_ACTOR=axesso_data/amazon-search-scraper

# Cap products fetched per restock query (default 6).
APIFY_PRODUCTS_MAX=6

# Set to 1 to skip the live product scrape when /api/restock is hit.
APIFY_PRODUCTS_DISABLED=

# Optional Socrata app token for higher DataSF rate limits.
SOCRATA_APP_TOKEN=optional_datasf_socrata_app_token

# Optional WorldMonitor hook (currently unused).
WORLD_MONITOR_KEY=optional_worldmonitor_key

# Anthropic API key for the live LLM chatbot. Without it, the chatbot
# falls back to rule-based responses. Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Optional: override the model. Default is claude-haiku-4-5-20251001 (fast, cheap).
# For higher-quality but slower responses use claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Gemini fallback for the live LLM chatbot. If ANTHROPIC_API_KEY is empty and
# GEMINI_API_KEY is set, /api/chat uses Gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Hackathon delegated-agent layer. Leave blank for the built-in demo mode.
# Tomorrow, swap these to the sponsor credentials and set live proxy URLs if
# you want Warden to call sponsor-backed endpoints instead of mock records.
SCALEKIT_ENVIRONMENT_URL=
SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=
SCALEKIT_MODE=mock
SCALEKIT_AGENT_PROXY_URL=

ENTIRE_API_KEY=
ENTIRE_API_URL=
ENTIRE_WORKSPACE_ID=
ENTIRE_MODE=mock

# Optional demo identity/customer-memory values. Keep real demo emails in your
# local .env only; they should not be committed.
DEMO_OWNER_EMAIL=owner@example.com
DEMO_CUSTOMER_EMAIL=regular.customer@example.com

# Server port (default 4173).
PORT=4173
